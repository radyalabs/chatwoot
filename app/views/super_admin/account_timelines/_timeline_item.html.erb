<div class="relative flex gap-4">
  <!-- Icon -->
  <div class="relative z-10">
    <div class="w-12 h-12 bg-white border-2 border-blue-500 rounded-full flex items-center justify-center">
      <i class="<%= event[:icon] %> text-blue-600 text-lg"></i>
    </div>
  </div>

  <!-- Content -->
  <div class="flex-1 bg-white border border-slate-200 rounded-lg p-4">
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1">
        <h3 class="font-semibold text-slate-900"><%= event[:title] %></h3>
        <% if event[:description].present? %>
          <p class="mt-1 text-sm text-slate-600"><%= event[:description] %></p>
        <% end %>
        
        <% if event[:metadata]&.[](:ip) %>
          <div class="mt-2 text-xs text-slate-500 font-mono bg-slate-50 inline-block px-2 py-1 rounded">
            IP: <%= event[:metadata][:ip] %>
          </div>
        <% end %>
      </div>
      
      <div class="text-right">
        <div class="text-sm text-slate-600">
          <%= event[:timestamp].in_time_zone.strftime('%d %b %Y, %H.%M %Z') %>
        </div>
        <div class="text-xs text-slate-400 mt-1"><%= event[:type].to_s.humanize %></div>
      </div>
    </div>
  </div>
</div>
