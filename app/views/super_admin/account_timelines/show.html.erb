<% content_for(:title) do %>
  Timeline: <%= @user.name %>
<% end %>

<header class="main-content__header" role="banner">
  <h1 class="main-content__page-title" id="page-title">
    <%= content_for(:title) %>
  </h1>

  <div>
    <%= link_to "← Back to List", 
        super_admin_account_timelines_path,
        class: "text-slate-600 hover:text-slate-800" %>
  </div>
</header>

<section class="main-content__body">
  <!-- User Info Card -->
  <div class="bg-white border border-slate-200 rounded-lg p-6 mb-8">
    <div class="flex items-start gap-4">
      <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 text-2xl font-bold">
        <%= @user.name.first.upcase %>
      </div>
      <div class="flex-1">
        <h2 class="text-xl font-semibold text-slate-900"><%= @user.name %></h2>
        <p class="text-slate-600"><%= @user.email %></p>
        <div class="mt-2 flex gap-4 text-sm text-slate-500">
          <span>Registered: <span data-browser-datetime="<%= @user.created_at.to_i %>"></span></span>
          <span>•</span>
          <span>Sign Ins: <%= @user.sign_in_count %></span>
          <span>•</span>
          <span>Email Verified: <%= @user.confirmed_at? ? 'Yes' : 'No' %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Timeline -->
  <div class="relative">
    <% if @timeline.present? %>
      <div class="absolute left-6 top-0 bottom-0 w-px bg-slate-200"></div>
      
      <div class="space-y-6">
        <% @timeline.each do |event| %>
          <%= render partial: "timeline_item", locals: { event: event } %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-slate-900">No activity recorded</h3>
        <p class="mt-1 text-sm text-slate-500">
          This user hasn't performed any activities yet.
        </p>
      </div>
    <% end %>
  </div>
</section>
