<%#
# Show

This view is the template for the show page.
It renders the attributes of a resource,
as well as a link to its edit page.

## Local variables:

- `page`:
  An instance of [Administrate::Page::Show][1].
  Contains methods for accessing the resource to be displayed on the page,
  as well as helpers for describing how each attribute of the resource
  should be displayed.

[1]: http://www.rubydoc.info/gems/administrate/Administrate/Page/Show
%>

<% content_for(:title) { t("administrate.actions.show_resource", name: page.page_title) } %>

<header class="main-content__header" role="banner">
  <h1 class="main-content__page-title">
    <%= content_for(:title) %>
  </h1>

  <div>
    <%= link_to(
      "Edit",
      [:edit, namespace, page.resource],
      class: "button",
    ) if accessible_action?(page.resource, :edit) %>
  </div>
</header>

<section class="main-content__body">
  <dl>
    <% page.attributes.each do |title, attributes| %>
      <fieldset class="<%= "field-unit--nested" if title.present? %>">
        <% if title.present? %>
          <legend><%= t "helpers.label.#{page.resource_name}.#{title}", default: title %></legend>
        <% end %>

        <% attributes.each do |attribute| %>
          <dt class="attribute-label" id="<%= attribute.name %>">
          <%= t(
            "helpers.label.#{resource_name}.#{attribute.name}",
            default: page.resource.class.human_attribute_name(attribute.name),
          ) %>
          </dt>

          <dd class="attribute-data attribute-data--<%=attribute.html_class%>"
              ><%= render_field attribute, page: page %></dd>
        <% end %>
      </fieldset>
    <% end %>
  </dl>
</section>

<section class="main-content__body">
  <% account_user_page = Administrate::Page::Form.new(AccountUserDashboard.new, AccountUser.new) %>
  <%= form_for([namespace, account_user_page.resource], html: { class: "form" }) do |f| %>
  <% if account_user_page.resource.errors.any? %>
    <div id="error_explanation">
      <h2>
        <%= t(
          "administrate.form.errors",
          pluralized_errors: pluralize(account_user_page.resource.errors.count, t("administrate.form.error")),
          resource_name: display_resource_name(account_user_page.resource_name)
        ) %>
      </h2>

      <ul>
        <% account_user_page.resource.errors.full_messages.each do |message| %>
          <li class="flash-error"><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% account_user_page.attributes.each do |title, attributes| -%>
    <% attributes.each do |attribute| %>
      <% if attribute.name == "account" %>
        <%= f.hidden_field('account_id', value: page.resource.id) %>
      <% else %>
      <div class="field-unit field-unit--<%= attribute.html_class %> field-unit--<%= requireness(attribute) %>">
        <%= render_field attribute, f: f %>
      </div>
      <% end %>
    <% end %>
  <% end -%>

  <div class="form-actions">
    <%= f.submit %>
  </div>
<% end %>

</section>

<section class="main-content__body">
  <style>
    .inboxes-container {
      max-height: 70vh;
      overflow-y: auto;
      padding-right: 8px;
    }
    .inboxes-container::-webkit-scrollbar {
      width: 8px;
    }
    .inboxes-container::-webkit-scrollbar-track {
      background: #f5f5f5;
      border-radius: 4px;
    }
    .inboxes-container::-webkit-scrollbar-thumb {
      background: #ccc;
      border-radius: 4px;
    }
    .inboxes-container::-webkit-scrollbar-thumb:hover {
      background: #999;
    }
    .inbox-section {
      margin-bottom: 24px;
    }
    .inbox-header {
      padding: 12px 16px;
      background: #f5f5f5;
      border-radius: 6px 6px 0 0;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: background 0.2s;
    }
    .inbox-header:hover {
      background: #efefef;
    }
    .inbox-header strong {
      font-size: 14px;
      color: #111;
    }
    .inbox-badge {
      background: #0b2a4a;
      color: #fff;
      font-size: 12px;
      padding: 3px 8px;
      border-radius: 12px;
      font-weight: 500;
    }
    .inbox-header-toggle {
      font-size: 12px;
      color: #667781;
    }
    .inbox-content {
      padding: 16px;
      background: #fff;
      border-radius: 0 0 6px 6px;
      border: 1px solid #e0e0e0;
      border-top: none;
      max-height: 400px;
      overflow-y: auto;
    }
    .inbox-content::-webkit-scrollbar {
      width: 6px;
    }
    .inbox-content::-webkit-scrollbar-track {
      background: transparent;
    }
    .inbox-content::-webkit-scrollbar-thumb {
      background: #ddd;
      border-radius: 3px;
    }
    .inbox-content::-webkit-scrollbar-thumb:hover {
      background: #999;
    }
    .contact-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .contact-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px;
      border-bottom: 1px solid #f0f0f0;
      transition: background 0.15s;
    }
    .contact-item:hover {
      background: #fafafa;
    }
    .contact-item:last-child {
      border-bottom: none;
    }
    .contact-info {
      flex: 1;
      min-width: 0;
    }
    .contact-name {
      font-weight: 500;
      color: #111;
      font-size: 13px;
      margin-bottom: 2px;
    }
    .contact-identifier {
      font-size: 12px;
      color: #667781;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .conversation-count {
      display: inline-block;
      background: #e8f0fe;
      color: #0b2a4a;
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 12px;
      margin-top: 4px;
    }
    .contact-actions {
      margin-left: 12px;
      flex-shrink: 0;
    }
    .chat-link {
      display: inline-block;
      padding: 6px 12px;
      background: #0b2a4a;
      color: #fff;
      border-radius: 4px;
      font-size: 12px;
      text-decoration: none;
      transition: background 0.2s;
    }
    .chat-link:hover {
      background: #0a1f38;
    }
    .last-conversation {
      display: inline-block;
      font-size: 11px;
      color: #999;
      margin-top: 4px;
    }
  </style>

  <h2 class="main-content__page-title">Inboxes and Contacts</h2>
  <div class="inboxes-container">
    <% if defined?(@inboxes) && @inboxes.present? %>
    <% @inboxes.each_with_index do |inbox, idx| %>
      <div class="inbox-section">
        <details>
          <summary class="inbox-header">
            <div style="display: flex; gap: 12px; align-items: center; flex: 1;">
              <strong>📧 <%= inbox.name %></strong>
              <span class="inbox-badge"><%= inbox.contact_inboxes.size %> contact<%= inbox.contact_inboxes.size != 1 ? 's' : '' %></span>
            </div>
            <span class="inbox-header-toggle">▼</span>
          </summary>
          <div class="inbox-content">
            <% if inbox.contact_inboxes.empty? %>
              <p style="color: #667781; font-size: 13px; margin: 0;">No contacts in this inbox</p>
            <% else %>
              <ul class="contact-list">
                <% sorted_contacts = inbox.contact_inboxes.sort_by { |ci| @latest_session[[inbox.id, ci.contact.id]] || Time.at(0) }.reverse %>
                <% sorted_contacts.each do |ci| %>
                  <% c = ci.contact %>
                  <% last_conversation = @latest_session[[inbox.id, c.id]] %>
                  <li class="contact-item">
                    <div class="contact-info">
                      <div class="contact-name">👤 <%= c&.name || 'Unknown Contact' %></div>
                      <div class="contact-identifier"><%= c&.email || c&.phone_number || 'No identifier' %></div>
                      <div class="conversation-count"><%= pluralize(@conversation_counts[[inbox.id, c.id]] || 0, 'conversation') %></div>
                      <% if last_conversation %>
                        <div class="last-conversation">Latest session: <span data-epoch="<%= last_conversation.to_i %>"><%= last_conversation.strftime('%d %b %Y, %H:%M') %></span></div>
                      <% end %>
                    </div>
                    <div class="contact-actions">
                      <%= link_to 'View Messages', super_admin_account_contact_conversations_path(page.resource, inbox_id: inbox.id, contact_id: c.id), class: 'chat-link' %>
                    </div>
                  </li>
                <% end %>
              </ul>
            <% end %>
          </div>
        </details>
      </div>
    <% end %>
  <% else %>
    <p style="color: #667781; font-size: 14px;">No inboxes found for this account.</p>
  <% end %>
  </div>
</section>

<script>
  // Format latest session timestamps in contact list to browser's local timezone
  document.addEventListener('DOMContentLoaded', () => {
    const latestSessionFormatter = new Intl.DateTimeFormat([], { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
    document.querySelectorAll('.last-conversation [data-epoch]').forEach(el => {
      const epoch = Number(el.dataset.epoch) * 1000;
      if (Number.isFinite(epoch)) {
        el.textContent = latestSessionFormatter.format(new Date(epoch));
      }
    });
  });
</script>

<%= render partial: "seed_data", locals: {page: page} %>

<%= render partial: "reset_cache", locals: {page: page} %>
