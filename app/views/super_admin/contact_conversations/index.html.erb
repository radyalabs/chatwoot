<% content_for(:title) do %>
  Contact History
<% end %>

<style>
.main-content__body {
  padding: 0;
  margin: 0;
}
.chat-container {
  width: 100%;
  margin: 0;
  background: #ffff;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 1px 2px rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
  height: calc(100vh - 100px);
}
.chat-header {
  background: #f0f2f5;
  padding: 12px 20px;
  border-bottom: 1px solid #ddd;
  flex-shrink: 0;
}
.chat-header h3 {
  margin: 0 0 4px 0;
  font-size: 15px;
  font-weight: 500;
  color: #111;
}
.chat-header small {
  color: #667781;
  font-size: 13px;
}
.messages-container {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 16px 20px;
  flex: 1;
  overflow-y: auto;
  background: #e6e6e6;
  background-image: 
    repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,.05) 35px, rgba(255,255,255,.05) 70px);
}
.messages-container::-webkit-scrollbar {
  width: 6px;
}
.messages-container::-webkit-scrollbar-track {
  background: transparent;
}
.messages-container::-webkit-scrollbar-thumb {
  background: rgba(0,0,0,0.2);
  border-radius: 3px;
}
.conversation-divider {
  align-self: center;
  background: #fff;
  color: #667781;
  font-size: 12px;
  font-weight: 500;
  padding: 6px 16px;
  border-radius: 8px;
  margin: 16px 0 8px 0;
  box-shadow: 0 1px 2px rgba(0,0,0,0.1);
  text-align: center;
}
.message-bubble {
  display: flex;
  flex-direction: column;
  max-width: 60%;
  padding: 6px 10px;
  border-radius: 7px;
  position: relative;
  word-wrap: break-word;
  box-shadow: 0 1px 0.5px rgba(0,0,0,0.1);
}
.message-bubble.incoming {
  align-self: flex-start;
  background: #fff;
  color: #111;
  border-radius: 0 7px 7px 7px;
}
.message-bubble.outgoing {
  align-self: flex-end;
  background: #d9fdd3;
  color: #111;
  border-radius: 7px 0 7px 7px;
}
.message-bubble.template {
  align-self: flex-end;
  background: #cfe9ff;
  color: #0b2a4a;
  border-radius: 7px 0 7px 7px;
}
.message-bubble.activity {
  align-self: center;
  background: #fff4ce;
  color: #54656f;
  font-size: 12px;
  max-width: 70%;
  text-align: center;
  border-radius: 7px;
  padding: 5px 10px;
  box-shadow: none;
  margin: 6px 0;
}
.message-sender {
  font-weight: 500;
  font-size: 12px;
  margin-bottom: 0;
  color: #667781;
  text-align: left;
}
.message-content {
  font-size: 14px;
  line-height: 1.3;
  color: #111;
  white-space: pre-wrap;
  margin: 2px 0;
  padding: 2px 0;
  text-align: left;
}
.message-time {
  font-size: 10px;
  color: #667781;
  text-align: right;
  margin-top: 0;
}
.back-button {
  display: inline-block;
  margin-bottom: 8px;
  padding: 8px 16px;
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 6px;
  text-decoration: none;
  color: #111;
  font-size: 14px;
  transition: background 0.2s;
}
.back-button:hover {
  background: #f5f5f5;
}
</style>

<header class="main-content__header" role="banner">
  <h1 class="main-content__page-title">
    <%= "Inbox: #{@inbox.name}" %>
  </h1>
  <div>
    <%= link_to "Back to Account", [:super_admin, @account], class: "button" %>
  </div>
</header>

<section class="main-content__body">
  <% if @conversations.blank? %>
    <p>No conversations found for this contact in this inbox.</p>
  <% else %>
    <div class="chat-container">
      <div class="chat-header">
        <h3><%= @contact.name || @contact.email || @contact.phone_number || 'Contact #' + @contact.id.to_s %></h3>
        <small><%= @conversations.count %> conversation(s)</small>
      </div>
      <div class="messages-container">
        <% @conversations.each_with_index do |conversation, conv_idx| %>
          <% if conv_idx > 0 %>
            <div class="conversation-divider">
              Conversation #<%= conversation.display_id %> • <span class="conversation-time" data-epoch="<%= conversation.created_at.to_i %>"><%= conversation.created_at&.strftime('%d %b %Y, %H:%M') %></span> • <%= conversation.status %>
            </div>
          <% else %>
            <div class="conversation-divider">
              Conversation #<%= conversation.display_id %> • <span class="conversation-time" data-epoch="<%= conversation.created_at.to_i %>"><%= conversation.created_at&.strftime('%d %b %Y, %H:%M') %></span>
            </div>
          <% end %>
          <% conversation.messages.order(created_at: :asc).each do |message| %>
            <%
              is_outgoing = message.message_type == 'outgoing'
              is_incoming = message.message_type == 'incoming'
              is_activity = message.message_type == 'activity'
              is_template = message.message_type == 'template'
              sender_name = message.sender&.try(:name) || message.sender_type || 'Template'
              sender_type = message.sender_type.to_s
              icon = if is_template
                       '🧩'
                     elsif sender_type.match?(/agentbot|aiagent|bot/i)
                       '🤖'
                     else
                       '👤'
                     end
              sender_label = "#{icon} #{sender_name}"
              bubble_class = if is_activity
                                'activity'
                              elsif is_template
                                'template'
                              elsif is_outgoing
                                'outgoing'
                              else
                                'incoming'
                              end
            %>
            <div class="message-bubble <%= bubble_class %>">
              <% unless is_activity %><div class="message-sender"><%= sender_label %></div><% end %>
              <div class="message-content"><% if message.content.present? %><%= message.content.strip %><% elsif message.content_type.present? %>📎 <%= message.content_type %><% elsif message.content_attributes.present? %>📎 Attachment<% else %>💬 [Message]<% end %></div>
              <div class="message-time" data-epoch="<%= message.created_at.to_i %>"><%= message.created_at&.strftime('%H:%M') %></div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</section>

<script>
  // Format times to the browser's local timezone for consistency with the SPA views
  document.addEventListener('DOMContentLoaded', () => {
    const msgFormatter = new Intl.DateTimeFormat([], { hour: '2-digit', minute: '2-digit' });
    document.querySelectorAll('.message-time[data-epoch]').forEach(el => {
      const epoch = Number(el.dataset.epoch) * 1000;
      if (Number.isFinite(epoch)) {
        el.textContent = msgFormatter.format(new Date(epoch));
      }
    });

    const convFormatter = new Intl.DateTimeFormat([], { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit', hour12: false });
    document.querySelectorAll('.conversation-time[data-epoch]').forEach(el => {
      const epoch = Number(el.dataset.epoch) * 1000;
      if (Number.isFinite(epoch)) {
        el.textContent = convFormatter.format(new Date(epoch));
      }
    });
  });
</script>
